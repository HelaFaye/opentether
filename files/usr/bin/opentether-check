#!/bin/sh
# opentether-check — multi-device status diagnostic
# Exit code: 0 = all healthy, 1 = degraded, 2 = one or more down

SEP="────────────────────────────────────────"
section() { printf '\n%s\n %s\n%s\n' "$SEP" "$1" "$SEP"; }

STATUS=0

section "ADB Devices"
adb devices

# Iterate over all configured devices
DEVICES=$(uci show opentether 2>/dev/null | \
    awk -F= '/[.]serial=/{v=$2; gsub(/\x27/,"",v); print v}')

if [ -z "$DEVICES" ]; then
    echo "No devices configured."
    exit 0
fi

for DEVICE in $DEVICES; do
    CFG=$(uci show opentether 2>/dev/null | \
        awk -F= -v s="$DEVICE" '/[.]serial=/{v=$2; gsub(/\x27/,"",v); if(v==s){split($1,a,"."); print a[2]}}' | head -1)
    PORT="$(uci -q get opentether.${CFG}.port    || echo 1088)"
    IFACE="$(uci -q get opentether.${CFG}.iface  || echo s5tun0)"
    NAME="$(uci -q get opentether.${CFG}.name    || echo '')"
    LOGFILE="$(uci -q get opentether.${CFG}.log_file || echo '')"
    ENABLED="$(uci -q get opentether.${CFG}.enabled || echo 0)"

    printf '\n%s\n Device: %s%s\n%s\n' "$SEP" "$DEVICE" \
        "$([ -n "$NAME" ] && echo " — $NAME")" "$SEP"

    echo "Enabled:  $ENABLED"
    echo "Port:     $PORT"
    echo "Interface:$IFACE"

    # Forward
    printf '\nPort Forward (tcp:%s):\n' "$PORT"
    if adb -s "$DEVICE" forward --list 2>/dev/null | grep -q "${PORT}"; then
        adb -s "$DEVICE" forward --list
    else
        echo "(none)"
        [ $STATUS -lt 1 ] && STATUS=1
    fi

    # Tunnel process
    printf '\nTunnel Process:\n'
    PIDFILE="/tmp/opentether-tunnel-${DEVICE}.pid"
    if [ -f "$PIDFILE" ] && kill -0 "$(cat $PIDFILE)" 2>/dev/null; then
        echo "Running (PID $(cat $PIDFILE))"
    else
        echo "NOT RUNNING"
        [ "$ENABLED" = "1" ] && STATUS=2
    fi

    # Interface
    printf '\nInterface (%s):\n' "$IFACE"
    if ip addr show dev "$IFACE" 2>/dev/null | grep -q "$IFACE"; then
        ip addr show dev "$IFACE"
    else
        echo "${IFACE} not found"
        [ "$ENABLED" = "1" ] && STATUS=2
    fi

    # Connectivity
    printf '\nConnectivity:\n'
    V4="$(curl -4 -s --max-time 5 https://ifconfig.co 2>/dev/null)"
    if [ -n "$V4" ]; then echo "IPv4: $V4"; else echo "IPv4: FAILED"; STATUS=2; fi
    V6="$(curl -6 -s --max-time 5 https://ifconfig.co 2>/dev/null)"
    if [ -n "$V6" ]; then echo "IPv6: $V6"; else echo "IPv6: NOT AVAILABLE"; fi

    # Log
    printf '\nLog (last 20 lines):\n'
    if [ -z "$LOGFILE" ] || [ "$LOGFILE" = "stdout" ] || [ "$LOGFILE" = "stderr" ]; then
        { /sbin/logread -e "opentether" 2>/dev/null || logread -e "opentether" 2>/dev/null; } \
            | grep "\[$DEVICE\]" | tail -20
    elif [ -f "$LOGFILE" ]; then
        grep "\[$DEVICE\]" "$LOGFILE" | tail -20
    fi
done

printf '\n%s\n' "$SEP"
case $STATUS in
    0) echo " Status: ALL HEALTHY" ;;
    1) echo " Status: DEGRADED" ;;
    2) echo " Status: ONE OR MORE DEVICES DOWN" ;;
esac
printf '%s\n' "$SEP"

exit $STATUS
