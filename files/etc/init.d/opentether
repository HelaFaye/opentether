#!/bin/sh /etc/rc.common
# OpenTether init service
# Manages the hev-socks5-tunnel process only.
# ADB setup and port forwarding are handled by the USB hotplug script.

START=99
STOP=10
USE_PROCD=1

TUNNEL_BIN=/usr/bin/hev-socks5-tunnel
TUNNEL_CFG=/etc/hev-socks5-tunnel/main.yml

start_service() {
    [ -x "$TUNNEL_BIN" ] || { logger -t opentether "ERROR: $TUNNEL_BIN not found"; return 1; }
    [ -f "$TUNNEL_CFG" ] || { logger -t opentether "ERROR: $TUNNEL_CFG not found"; return 1; }

    procd_open_instance
    procd_set_param command "$TUNNEL_BIN" "$TUNNEL_CFG"
    procd_set_param respawn 3600 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

stop_service() {
    # Let procd handle teardown — do not killall here as it confuses
    # procd's process tracking and respawn counter
    return 0
}

reload_service() {
    stop
    start
}
