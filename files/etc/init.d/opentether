#!/bin/sh /etc/rc.common
# OpenTether init service
# Uses procd named instances — one per configured device.
# ADB setup and port forwarding are handled by the USB hotplug script.

START=99
STOP=10
USE_PROCD=1

TUNNEL_BIN=/usr/bin/hev-socks5-tunnel
YAML_DIR=/etc/hev-socks5-tunnel/devices

start_service() {
    [ -x "$TUNNEL_BIN" ] || { logger -t opentether "ERROR: $TUNNEL_BIN not found"; return 1; }

    config_load opentether
    config_foreach _start_device device
}

_start_device() {
    local cfg="$1"
    local serial enabled yaml

    config_get serial  "$cfg" serial  ''
    config_get enabled "$cfg" enabled '0'

    [ -n "$serial" ]  || return
    [ "$enabled" = "1" ] || return

    yaml="${YAML_DIR}/${serial}.yml"
    [ -f "$yaml" ] || { logger -t opentether "WARN: no YAML for $serial — skipping"; return; }

    logger -t opentether "Starting tunnel instance: $serial"
    procd_open_instance "$serial"
    procd_set_param command "$TUNNEL_BIN" "$yaml"
    procd_set_param respawn 3600 5 5
    procd_set_param pidfile "/tmp/opentether-tunnel-${serial}.pid"
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

stop_service() {
    return 0
}

reload_service() {
    stop
    start
}

