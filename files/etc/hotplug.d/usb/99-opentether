#!/bin/sh
# /etc/hotplug.d/usb/99-opentether
# Per-device handler: one lock and one watchdog per device serial.

_port_for_serial() {
    local serial="$1"
    local cfg
    cfg=$(uci show opentether 2>/dev/null | \
          awk -F= -v s="$serial" '/[.]serial=/{v=$2; gsub(/\x27/,"",v); if(v==s){split($1,a,"."); print a[2]}}' | head -1)
    [ -n "$cfg" ] && uci -q get "opentether.${cfg}.port" && return
    echo ""
}

_is_configured() {
    local serial="$1"
    local cfg enabled
    cfg=$(uci show opentether 2>/dev/null | \
          awk -F= -v s="$serial" '/[.]serial=/{v=$2; gsub(/\x27/,"",v); if(v==s){split($1,a,"."); print a[2]}}' | head -1)
    [ -z "$cfg" ] && return 1
    enabled="$(uci -q get "opentether.${cfg}.enabled" 2>/dev/null)"
    [ "$enabled" = "1" ] && return 0 || return 1
}

_stop_instance() {
    local serial="$1"
    ubus call service set '{"name":"opentether","instances":{"'"$serial"'":{"action":"stop"}}}' 2>/dev/null || true
    rm -f "/tmp/opentether-tunnel-${serial}.pid"
}

_restart_instance() {
    local serial="$1"
    _stop_instance "$serial"
    sleep 1
    /etc/init.d/opentether start
}

# ACTION=remove: clean up watchdogs for disconnected devices
if [ "$ACTION" = "remove" ]; then
    rm -rf /tmp/opentether-add.lock 2>/dev/null
    for pidfile in /tmp/opentether-watchdog-*.pid; do
        [ -f "$pidfile" ] || continue
        serial="${pidfile#/tmp/opentether-watchdog-}"
        serial="${serial%.pid}"
        # Double-check state with a gap to defeat adb server caching
        state1="$(adb -s "$serial" get-state 2>/dev/null)"
        sleep 1
        state2="$(adb -s "$serial" get-state 2>/dev/null)"
        if [ "$state1" = "device" ] && [ "$state2" = "device" ]; then
            continue
        fi
        logger -t opentether "[$serial] USB removed — cleaning up"
        kill "$(cat $pidfile)" 2>/dev/null
        rm -f "$pidfile"
        rm -rf "/tmp/opentether-${serial}.lock"
        adb -s "$serial" forward --remove-all 2>/dev/null || true
        _stop_instance "$serial"
    done
    exit 0
fi

[ "$ACTION" = "add" ] || exit 0

# Global add lock — only one USB add handler at a time
# Prevents multiple USB interface events from each calling adb start-server
# and triggering multiple authorization prompts on the phone
mkdir /tmp/opentether-add.lock 2>/dev/null || exit 0

# Brief pause — let adb server settle after USB event
sleep 1

adb start-server 2>/dev/null

# Wait for any authorized device
retries=60
DEVICE=""
while [ $retries -gt 0 ] && [ -z "$DEVICE" ]; do
    DEVICE="$(adb devices 2>/dev/null | awk '/\tdevice$/{print $1; exit}')"
    [ -z "$DEVICE" ] && sleep 1
    retries=$((retries - 1))
done

rm -rf /tmp/opentether-add.lock

if [ -z "$DEVICE" ]; then
    logger -t opentether "WARNING: ADB authorization timed out after 60s"
    exit 1
fi

logger -t opentether "[$DEVICE] ADB authorized"

# Per-device lock — prevents duplicate handlers for same serial
mkdir "/tmp/opentether-${DEVICE}.lock" 2>/dev/null || { rm -rf /tmp/opentether-add.lock; exit 0; }

rm -rf /tmp/opentether-add.lock

(
    PIDFILE="/tmp/opentether-watchdog-${DEVICE}.pid"
    echo $$ > "$PIDFILE"

    if ! _is_configured "$DEVICE"; then
        logger -t opentether "[$DEVICE] detected but not configured — skipping tunnel"
        rm -f "$PIDFILE"
        rm -rf "/tmp/opentether-${DEVICE}.lock"
        exit 0
    fi

    PORT="$(_port_for_serial "$DEVICE")"
    logger -t opentether "[$DEVICE] configured on port $PORT — setting forward"

    # Remove any stale forward first
    adb -s "$DEVICE" forward --remove-all 2>/dev/null || true

    # Set forward with retries
    fwd_ok=0
    for attempt in 1 2 3; do
        adb -s "$DEVICE" forward tcp:${PORT} tcp:${PORT} 2>/dev/null
        sleep 1
        if adb -s "$DEVICE" forward --list 2>/dev/null | grep -q "${PORT}"; then
            logger -t opentether "[$DEVICE] forward active (attempt $attempt)"
            fwd_ok=1
            break
        fi
        logger -t opentether "[$DEVICE] forward attempt $attempt failed — retrying"
    done

    if [ $fwd_ok -eq 0 ]; then
        logger -t opentether "[$DEVICE] ERROR: adb forward failed after 3 attempts"
        rm -f "$PIDFILE"
        rm -rf "/tmp/opentether-${DEVICE}.lock"
        exit 1
    fi

    # Restart to ensure procd registers/starts a fresh instance
    _restart_instance "$DEVICE"
    sleep 2

    if ubus call service list '{"name":"opentether"}' 2>/dev/null | grep -q "\"$DEVICE\""; then
        logger -t opentether "[$DEVICE] tunnel instance started"
    else
        logger -t opentether "[$DEVICE] WARNING: tunnel instance did not start — check YAML"
    fi

    # Release lock so a reconnect can re-run setup if needed
    rm -rf "/tmp/opentether-${DEVICE}.lock"

    # Watchdog loop
    while true; do
        sleep 5

        STATE="$(adb -s "$DEVICE" get-state 2>/dev/null)"
        # Skip unauthorized — device is pending approval, not gone
        [ "$STATE" = "unauthorized" ] && continue
        if [ "$STATE" != "device" ]; then
            logger -t opentether "[$DEVICE] WATCHDOG: gone (state: ${STATE:-disconnected}) — stopping tunnel"
            logger -t opentether "[$DEVICE] WARNING: tunnel DOWN — no internet from this device"
            _stop_instance "$DEVICE"
            adb -s "$DEVICE" forward --remove-all 2>/dev/null || true
            rm -f "$PIDFILE"
            exit 0
        fi

        # Check forward still present
        if ! adb -s "$DEVICE" forward --list 2>/dev/null | grep -q "${PORT}"; then
            logger -t opentether "[$DEVICE] WATCHDOG: forward lost — re-establishing"
            adb -s "$DEVICE" forward tcp:${PORT} tcp:${PORT} 2>/dev/null
            sleep 1
            if ! adb -s "$DEVICE" forward --list 2>/dev/null | grep -q "${PORT}"; then
                logger -t opentether "[$DEVICE] WATCHDOG: forward unrestorable — stopping tunnel"
                logger -t opentether "[$DEVICE] WARNING: tunnel DOWN — no internet from this device"
                _stop_instance "$DEVICE"
                rm -f "$PIDFILE"
                exit 0
            fi
            logger -t opentether "[$DEVICE] WATCHDOG: forward restored — restarting tunnel"
            _restart_instance "$DEVICE"
            sleep 3
            continue
        fi

        # Check tunnel process alive via pgrep (more reliable than PID file)
        if ! pgrep -f "hev-socks5-tunnel.*${DEVICE}" >/dev/null 2>&1; then
            logger -t opentether "[$DEVICE] WATCHDOG: tunnel process died — restarting"
            _restart_instance "$DEVICE"
            sleep 2
            if ! adb -s "$DEVICE" forward --list 2>/dev/null | grep -q "${PORT}"; then
                logger -t opentether "[$DEVICE] WATCHDOG: re-establishing forward after restart"
                adb -s "$DEVICE" forward tcp:${PORT} tcp:${PORT} 2>/dev/null
            fi
        fi
    done
) &
