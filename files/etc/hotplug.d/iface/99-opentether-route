#!/bin/sh
# /etc/hotplug.d/iface/99-opentether-route
# Handles ifup and ifdown for ot_* interfaces.

# Only handle ot_* interfaces
case "$INTERFACE" in
    ot_*) ;;
    *) exit 0 ;;
esac

SERIAL="${INTERFACE#ot_}"
# UCI section name is always device_<serial> (enforced by setup.sh add-device)
MTU="$(uci -q get opentether.device_${SERIAL}.mtu    || echo 1440)"
METRIC="$(uci -q get opentether.device_${SERIAL}.metric || echo 10)"
IFACE="$(uci -q get opentether.device_${SERIAL}.iface  || echo s5tun0)"

if [ "$ACTION" = "ifup" ]; then
    logger -t opentether "[$SERIAL] Interface up — pinning routes (dev=$IFACE mtu=$MTU metric=$METRIC)"

    ip link set dev "$IFACE" mtu "$MTU" 2>/dev/null

    ip route add    default dev "$IFACE" metric "$METRIC" 2>/dev/null \
        || ip route replace default dev "$IFACE" metric "$METRIC"

    ip -6 route add    default dev "$IFACE" metric "$METRIC" 2>/dev/null \
        || ip -6 route replace default dev "$IFACE" metric "$METRIC"

    if ! grep -q "127.0.0.1" /etc/resolv.conf 2>/dev/null; then
        printf 'nameserver 127.0.0.1\nnameserver ::1\n' > /etc/resolv.conf
    fi

    logger -t opentether "[$SERIAL] Routes and resolver pinned"

elif [ "$ACTION" = "ifdown" ]; then
    logger -t opentether "[$SERIAL] Interface down — removing routes"
    ip route del default dev "$IFACE" 2>/dev/null || true
    ip -6 route del default dev "$IFACE" 2>/dev/null || true
fi
